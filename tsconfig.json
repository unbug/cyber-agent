{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@cyber-agent/sdk": ["sdk/src/index.ts"],
      "@cyber-agent/sdk/*": ["sdk/src/*.ts"],
      "@cyber-agent/sdk/trace": ["sdk/src/trace/schema.ts"],
      "@cyber-agent/sdk/plugin": ["sdk/src/plugin/index.ts"],
      "@cyber-agent/sdk/plugin/registry": ["sdk/src/plugin/registry.ts"],
      "@cyber-agent/sdk/plugin/sandbox": ["sdk/src/plugin/sandbox.ts"],
      "@cyber-agent/sdk/plugin/loader": ["sdk/src/plugin/loader.ts"]
    }
  },
  "include": ["src", "vite-env.d.ts"]
}
