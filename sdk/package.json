{
  "name": "@cyber-agent/sdk",
  "version": "1.0.0",
  "description": "CyberAgent SDK — Behavior Tree engine and Robot Adapter for AI characters",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cyber-agent",
    "behavior-tree",
    "robot",
    "ai-character",
    "embodied-ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unbug/cyber-agent",
    "directory": "sdk"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
